{
    "name": "mandalanet/isp2026",
    "description": "MandalaNet ISP 2026",
    "type": "project",
    "license": "MIT",

    "require": {
        "php": "^8.2"
    },

    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },

    "minimum-stability": "stable",
    "prefer-stable": true,

    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },

    "scripts": {
        "post-autoload-dump": [
            "@php -r \"echo 'Autoload berhasil diperbarui.' . PHP_EOL;\""
        ]
    }
}
